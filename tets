-- ЛОГИКА ФИЛЬТРАЦИИ
local loggedKeys = {}      -- Для уникальных "Имя+Args"
local callCounts = {}      -- Счетчик вызовов по имени
local isBlacklisted = {}   -- Список забаненных имен
local currentScript = ""

local function formatArgs(args)
    local parts = {}
    for i, v in ipairs(args) do
        local t = typeof(v)
        if t == "string" then table.insert(parts, '"'..v..'"')
        elseif t == "Instance" then table.insert(parts, v:GetFullName())
        else table.insert(parts, tostring(v)) end
    end
    return table.concat(parts, ", ")
end

local function addLog(rem, args)
    local name = rem.Name
    local argStr = formatArgs(args)
    local key = name .. "|" .. argStr

    -- 1. Если ивент в черном списке — полностью игнорируем
    if isBlacklisted[name] then return end

    -- 2. Считаем количество вызовов этого Remote
    callCounts[name] = (callCounts[name] or 0) + 1
    
    -- 3. Если вызван больше 10 раз — в бан (чтобы не спамил Replicator)
    if callCounts[name] > 10 then
        isBlacklisted[name] = true
        warn("[QuantumSpy] Remote '" .. name .. "' заблокирован из-за спама (>10 вызовов)")
        return
    end

    -- 4. Если такие аргументы уже были — скипаем
    if loggedKeys[key] then return end
    loggedKeys[key] = true

    local b = Instance.new("TextButton", Scroll)
    b.Size = UDim2.new(1, 0, 0, 28); b.Text = name; b.BackgroundColor3 = Color3.fromRGB(50, 50, 50); b.TextColor3 = Color3.new(1, 1, 1)
    
    b.MouseButton1Click:Connect(function()
        local path = rem:GetFullName()
        currentScript = path .. ":FireServer(" .. argStr .. ")"
        Details.Text = "Path: "..path.."\n\nArgs:\n"..argStr.."\n\nFull Script:\n"..currentScript
    end)
end

-- КНОПКИ
CopyArgs.MouseButton1Click:Connect(function() setclipboard(Details.Text) end)
CopyScript.MouseButton1Click:Connect(function() setclipboard(currentScript) end)

-- ХУК
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if (method == "FireServer" or method == "fireServer") and not checkcaller() then
        task.spawn(pcall, addLog, self, args)
    end
    return old(self, table.unpack(args))
end)
setreadonly(mt, true)
