                if p then 
                    ManualBannedPaths[p] = {details = "MANUALLY BLOCKED LOG:\n" .. d.fullText}
                    local nM = {}; for _, m in ipairs(MainMemory) do if not m.fullText:match("Path: " .. p) then table.insert(nM, m) end end
                    MainMemory = nM; lastCount = -1; updateRedList(); Details.Text = "EVENT BLOCKED"
                end; break
            end
        end
    end
end)

